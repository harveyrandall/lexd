{
  "name": "@lexd/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for compiling .lexd Lexicon DSL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harveyrandall/lexd.git",
    "directory": "packages/vite-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@lexd/core": "workspace:*",
    "@lexd/stdlib-atproto": "workspace:*",
    "@lexd/stdlib-standard": "workspace:*",
    "glob": "^11.0.2"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
