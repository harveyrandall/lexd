{
  "name": "vscode-lexd",
  "displayName": "Lexd (AT Proto Lexicon DSL)",
  "description": "Language support for .lexd — Lexicon DSL for AT Protocol",
  "version": "0.1.1",
  "publisher": "harveyrandall",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harveyrandall/lexd.git",
    "directory": "packages/vscode-lexd"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:lexd"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lexd",
        "aliases": [
          "Lexd",
          "lexd",
          "AT Proto Lexicon DSL"
        ],
        "extensions": [
          ".lexd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lexd",
        "scopeName": "source.lexd",
        "path": "./syntaxes/lexd.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node --import tsx scripts/bundle.mts",
    "watch": "tsc -p tsconfig.json --watch",
    "vscode:prepublish": "pnpm --filter @lexd/core run build && pnpm --filter @lexd/language-server run build && pnpm run build && pnpm run bundle",
    "package:vsix": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "release": "node --import tsx ../../scripts/release-vscode-extension.mts patch",
    "release:patch": "node --import tsx ../../scripts/release-vscode-extension.mts patch",
    "release:minor": "node --import tsx ../../scripts/release-vscode-extension.mts minor",
    "release:major": "node --import tsx ../../scripts/release-vscode-extension.mts major",
    "vscode:publish:patch": "pnpm exec vsce publish patch --no-dependencies",
    "vscode:publish:minor": "pnpm exec vsce publish minor --no-dependencies",
    "vscode:publish:major": "pnpm exec vsce publish major --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@lexd/language-server": "workspace:*",
    "@types/node": "^22.15.21",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
