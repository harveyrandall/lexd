import { StrongRef } from "com.atproto.repo.strongRef"

namespace app.bsky.feed {
  @record("tid")
  type post {
    @maxGraphemes(300) @maxLength(3000) text: string
    @format("datetime") createdAt: string
    reply?: Reply
    langs?: string[]
  }

  type Reply {
    root: StrongRef
    parent: StrongRef
  }
}
